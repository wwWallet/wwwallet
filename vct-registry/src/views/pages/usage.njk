{% extends "layouts/base.njk" %}

{% block title %}vct-registry usage{% endblock %}

{% block page_styles %}
<link rel="stylesheet" href="./styles/usage.css" />
{% endblock %}

{% block page_scripts %}
<script type="module" src="./js/usage.js"></script>
{% endblock %}

{% block content %}
<section class="page-shell">
  <div class="page-header">
    <h2>How To Fetch Metadata</h2>
    <p class="page-subtitle">
      Use these endpoints from backend services, scripts, or browser clients to integrate with the registry cleanly.
    </p>
  </div>
  <section class="card page-card usage-card">
    <p class="usage-text">
      Registry base URL: <code>{{ registryBaseUrl }}</code>
    </p>

    <h3>1. Fetch All Metadata</h3>
    <p class="usage-text">
      Endpoint: <code>GET {{ registryBaseUrl }}type-metadata/all</code>
    </p>
    <div class="usage-code-block">
      <button type="button" class="usage-copy-btn" data-copy-code="#usage-code-all" aria-label="Copy example" title="Copy example">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="9" y="9" width="10" height="10" rx="2"></rect>
          <rect x="5" y="5" width="10" height="10" rx="2"></rect>
        </svg>
        <span class="visually-hidden">Copy example</span>
      </button>
      <pre class="usage-code"><code id="usage-code-all">curl -s "{{ registryBaseUrl }}type-metadata/all"</code></pre>
    </div>

    <h3>2. Fetch One Metadata Entry By VCT</h3>
    <p class="usage-text">
      Endpoint: <code>GET {{ registryBaseUrl }}type-metadata?vct=&lt;vct-value&gt;</code>
    </p>
    <div class="usage-code-block">
      <button type="button" class="usage-copy-btn" data-copy-code="#usage-code-single" aria-label="Copy example" title="Copy example">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="9" y="9" width="10" height="10" rx="2"></rect>
          <rect x="5" y="5" width="10" height="10" rx="2"></rect>
        </svg>
        <span class="visually-hidden">Copy example</span>
      </button>
      <pre class="usage-code"><code id="usage-code-single">curl -s "{{ registryBaseUrl }}type-metadata?vct=urn:eudi:pid:1"</code></pre>
    </div>

    <h3>3. Browser Fetch Example</h3>
    <div class="usage-code-block">
      <button type="button" class="usage-copy-btn" data-copy-code="#usage-code-browser" aria-label="Copy example" title="Copy example">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="9" y="9" width="10" height="10" rx="2"></rect>
          <rect x="5" y="5" width="10" height="10" rx="2"></rect>
        </svg>
        <span class="visually-hidden">Copy example</span>
      </button>
      <pre class="usage-code"><code id="usage-code-browser">const vct = encodeURIComponent("urn:eudi:pid:1");
const res = await fetch(`{{ registryBaseUrl }}type-metadata?vct=${vct}`);
const metadata = await res.json();
console.log(metadata);</code></pre>
    </div>

    <h3>4. Optional: List Available VCTs (Name + VCT)</h3>
    <p class="usage-text">
      Endpoint: <code>GET {{ registryBaseUrl }}vct-list</code>
    </p>
    <div class="usage-code-block">
      <button type="button" class="usage-copy-btn" data-copy-code="#usage-code-list" aria-label="Copy example" title="Copy example">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="9" y="9" width="10" height="10" rx="2"></rect>
          <rect x="5" y="5" width="10" height="10" rx="2"></rect>
        </svg>
        <span class="visually-hidden">Copy example</span>
      </button>
      <pre class="usage-code"><code id="usage-code-list">curl -s "{{ registryBaseUrl }}vct-list"</code></pre>
    </div>
  </section>
</section>
{% endblock %}
