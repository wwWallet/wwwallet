{% extends "layouts/base.njk" %}

{% block title %}vct-registry{% endblock %}

{% block page_styles %}
<link rel="stylesheet" href="./styles/index.css" />
{% endblock %}

{% block content %}
<div id="vct-success" class="success" hidden></div>

<section class="page-shell metadata-shell">
  <div class="page-header metadata-hero-copy">
    <h2>Verifiable Credential Type Metadata</h2>
    <p class="page-subtitle metadata-description">
      Explore one credential definition at a time or inspect the full registry payload. This page is optimized for both quick browsing and raw JSON review.
    </p>
  </div>

  <div id="vct-add" class="metadata-header-action">
    <a id="vct-add-btn" class="vct-btn vct-edit-btn metadata-add-btn" href="add" hidden>Add new credential</a>
  </div>

  {% if metadataError %}
  <div id="vct-error" class="error">{{ metadataError }}</div>
  {% elif metadataList and metadataList.length %}
  <section class="card page-card metadata-selection-panel">
    <div class="metadata-panel-header">
      <h3>Selection</h3>
      <p class="metadata-panel-copy">Choose a VCT to inspect a single record, or switch to the complete registry response.</p>
    </div>

    <div class="metadata-selection-row">
      <form id="vct-select-form" class="metadata-select-form" method="GET" action="metadata">
          <select id="vct-select" class="vct-select" name="vct" onchange="this.form.submit()">
            <option value="__all__" {% if selectedVct == "__all__" %}selected{% endif %}>(All metadata)</option>
            {% for entry in metadataList %}
            <option value="{{ entry.vct | urlencode }}" {% if selectedVct == entry.vct %}selected{% endif %}>
              {{ entry.name }} ({{ entry.vct }})
            </option>
            {% endfor %}
          </select>
      </form>

      <div id="vct-edit" class="vct-edit" {% if selectedVct == "__all__" %}hidden{% endif %}>
        <form id="vct-edit-form" method="GET" action="edit">
          <input id="vct-edit-value" type="hidden" name="vct" value="{{ selectedVct | urlencode }}">
          <button id="vct-edit-btn" class="vct-btn vct-edit-btn metadata-edit-btn" type="submit" hidden>Edit credential</button>
        </form>
      </div>
    </div>
  </section>

  <div class="metadata-layout">
    <section class="card page-card metadata-sidebar">
      <div class="metadata-panel-header">
        <h3>Details</h3>
      </div>

      <div id="vct-controls" class="vct-controls">
        <dl id="vct-meta" class="vct-meta">
          {% if selectedVct == "__all__" %}
          <div class="metadata-stat">
            <dt class="metadata-stat-label">Showing</dt>
            <dd class="metadata-stat-value">All metadata entries</dd>
          </div>
          <div class="metadata-stat">
            <dt class="metadata-stat-label">Total entries</dt>
            <dd class="metadata-stat-value">{{ metadataList.length }}</dd>
          </div>
          <div class="metadata-stat">
            <dt class="metadata-stat-label">Source</dt>
            <dd class="metadata-stat-value metadata-stat-code"><code>GET {{ sourceUrl }}</code></dd>
          </div>
          {% elif selectedMetadata %}
          <div class="metadata-stat">
            <dt class="metadata-stat-label">VCT</dt>
            <dd class="metadata-stat-value metadata-stat-code"><code>{{ selectedMetadata.vct }}</code></dd>
          </div>
          <div class="metadata-stat">
            <dt class="metadata-stat-label">Name</dt>
            <dd class="metadata-stat-value">{{ selectedMetadata.name }}</dd>
          </div>
          {% if selectedMetadataPreview %}
          <div class="metadata-stat metadata-preview-stat">
            <dt class="metadata-stat-label">Preview</dt>
            <dd class="metadata-stat-value">
            <img
              class="metadata-preview"
              src="{{ selectedMetadataPreview }}"
              alt="{{ selectedMetadata.name or selectedMetadata.vct or 'Credential' }} preview"
            />
            </dd>
          </div>
          {% endif %}
          {% if selectedMetadata.description %}
          <div class="metadata-stat metadata-stat-description">
            <dt class="metadata-stat-label">Description</dt>
            <dd class="metadata-stat-value">{{ selectedMetadata.description }}</dd>
          </div>
          {% endif %}
          <div class="metadata-stat">
            <dt class="metadata-stat-label">Source</dt>
            <dd class="metadata-stat-value metadata-stat-code"><code>GET {{ sourceUrl }}</code></dd>
          </div>
          {% endif %}
        </dl>

        <div id="vct-delete" class="metadata-delete-action" {% if selectedVct == "__all__" %}hidden{% endif %}>
          <button id="vct-delete-btn" type="button" class="vct-btn vct-edit-btn delete" hidden>Delete credential</button>
        </div>
      </div>
    </section>

    <section class="card page-card metadata-json-panel">
      <div class="metadata-panel-header">
        <h3>Raw Metadata JSON</h3>
      </div>
      <pre id="vct-data" class="vct-data">{{ metadataJson }}</pre>
    </section>
  </div>
  <div class="metadata-inline-error">
    <div id="vct-error" class="error" hidden></div>
  </div>
  {% else %}
  <div id="vct-error" class="error">No VCT entries found.</div>
  {% endif %}
</section>
{% endblock %}

{% block page_scripts %}
<script type="module" src="./js/index.js"></script>
{% endblock %}
