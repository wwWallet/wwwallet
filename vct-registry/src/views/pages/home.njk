{% extends "layouts/base.njk" %}

{% block title %}vct-registry{% endblock %}

{% block page_styles %}
<link rel="stylesheet" href="./styles/home.css" />
{% endblock %}

{% block content %}
<section class="page-shell home-shell">
  <div class="page-header">
    <h1>Verifiable Credential TypeMetadata Registry</h1>
    <p class="page-subtitle home-subtitle">
      Browse and inspect SD-JWT Verifiable Credential Type metadata from one local registry.
    </p>
  </div>

  <div class="home-actions">
    <a class="vct-btn" href="metadata">Open Metadata Explorer</a>
  </div>

  {% if homeError %}
  <div class="error">{{ homeError }}</div>
  {% elif metadataList and metadataList.length %}
  <div class="home-cards">
    {% for metadata in metadataList %}
    <a class="home-metadata-card" href="metadata?vct={{ metadata.vct | urlencode }}">
      {% if metadata.dataUri %}
      <img
        class="home-preview"
        src="{{ metadata.dataUri }}"
        alt="{{ metadata.name or metadata.vct or 'Credential' }} preview"
        loading="lazy"
      />
      {% endif %}
      <h3>{{ metadata.name or metadata.vct or "Unnamed credential" }}</h3>
      <p class="home-vct">{{ metadata.vct or "" }}</p>
      <p class="home-description">{{ metadata.description or "No description provided." }}</p>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <div class="status-text">No metadata entries found.</div>
  {% endif %}
</section>
{% endblock %}
