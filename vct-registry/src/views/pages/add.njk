{% extends "layouts/base.njk" %}

{% block title %}vct-registry{% endblock %}

{% block page_styles %}
<link rel="stylesheet" href="./styles/add.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jsoneditor@latest/dist/jsoneditor.min.css" />
<link rel="stylesheet" href="./styles/jsoneditor.css" />
{% endblock %}

{% block content %}
<section class="page-shell">
  <div class="page-header">
    <h2>Create Verifiable Credential Type Metadata</h2>
    <p class="page-subtitle">
      Create a new registry entry by defining the VCT identity and supplying its full metadata document.
    </p>
  </div>
  <div class="editor-layout">
    <section class="card page-card editor-sidebar">
      <div class="metadata-panel-header">
        <h3>Details</h3>
        <p class="metadata-panel-copy">Define the credential identity and preview how the metadata card will render.</p>
      </div>

      <dl class="vct-meta editor-meta">
        <div class="metadata-stat">
          <dt class="metadata-stat-label">VCT</dt>
          <dd id="edit-vct-id-value" class="metadata-stat-value metadata-stat-code"><code></code></dd>
        </div>
        <div class="metadata-stat">
          <dt class="metadata-stat-label">Name</dt>
          <dd id="edit-vct-name-value" class="metadata-stat-value">-</dd>
        </div>
        <div class="metadata-stat metadata-preview-stat">
          <dt class="metadata-stat-label">Preview</dt>
          <dd class="metadata-stat-value">
            <div id="metadata-preview-list" class="metadata-preview-list" hidden></div>
            <p id="metadata-preview-empty" class="editor-preview-empty">Preview will appear when metadata includes display information.</p>
          </dd>
        </div>
        <div class="metadata-stat metadata-stat-description">
          <dt class="metadata-stat-label">Description</dt>
          <dd id="edit-vct-description" class="metadata-stat-value">No description provided yet.</dd>
        </div>
      </dl>
    </section>

    <section class="card page-card editor-main">
      <div class="metadata-panel-header">
        <h3>Metadata JSON</h3>
        <p class="metadata-panel-copy">Edit the full type metadata document directly.</p>
      </div>

      <div id="jsoneditor" class="jsoneditor-host"></div>
      <div class="vct-edit-button-container">
        <a class="vct-btn vct-btn-cancel" href="./metadata">Cancel</a>
        <button id="vct-submit-btn" type="button" class="vct-btn vct-edit-btn submit">Create VCT</button>
      </div>

      <div id="vct-error" class="error" hidden></div>
      <div id="vct-success" class="success" hidden></div>
    </section>
  </div>
</section>
{% endblock %}

{% block page_scripts %}
<script src="https://cdn.jsdelivr.net/npm/jsoneditor@latest"></script>
<script type="module" src="./js/add.js"></script>
{% endblock %}
