<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <base href="{{ baseHref or '/' }}" />
  <title>{% block title %}vct-registry{% endblock %}</title>
  <link rel="stylesheet" href="./styles/style.css" />
  <link rel="stylesheet" href="./styles/header.css" />
  {% block page_styles %}{% endblock %}
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <header class="header" role="banner">
    <div class="header-inner">
      <div class="header-copy">
        <p class="header-kicker">wwWallet</p>
        <h1>VCT Registry</h1>
        <p class="subtitle">
          Local SD-JWT Verifiable Credential Type Metadata registry
        </p>
      </div>
      <div class="vct-auth-button-container">
        <button id="vct-login-btn" type="button" class="vct-auth-btn login">Login</button>
        <span id="username-container" class="vct-user-indicator" hidden aria-label="Logged in user" tabindex="0">
          <span class="vct-user-avatar" aria-hidden="true"></span>
        </span>
        <button id="vct-logout-btn" type="button" class="vct-auth-btn logout" hidden>Logout</button>
      </div>
    </div>
  </header>

  <main id="main-content" class="container">
    {% block content %}{% endblock %}
  </main>

  <footer class="footer"></footer>

  <script type="module" src="./js/header.js"></script>
  {% block page_scripts %}{% endblock %}
</body>
</html>
